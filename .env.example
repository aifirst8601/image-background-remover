# Remove.bg API Key - Get one at https://www.remove.bg/api
REMOVE_BG_API_KEY=your_api_key_here

# Allowed origin - your website domain (e.g., https://your-domain.com, * for development
ALLOWED_ORIGIN=*

# Daily limit per IP address
DAILY_LIMIT_PER_IP=3

# Google OAuth - 使用与参考项目一致的变量名
# 获取方式: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# NextAuth - 生成方式: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=https://your-domain.pages.dev